<Window x:Class="NSC_ModManager.View.CharacterRosterEditorNS4View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NSC_ModManager"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"  
        xmlns:xcdg="http://schemas.xceed.com/wpf/xaml/datagrid"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:properties="clr-namespace:NSC_ModManager.Properties"
        Title="{DynamicResource m_rosterEditor}" Height="870" Width="900">
    <Window.Background>
        <ImageBrush ImageSource="{DynamicResource ResourceKey=TitleBackground}" Stretch="UniformToFill"/>
    </Window.Background>
    <Viewbox Stretch="{Binding Source={x:Static properties:Settings.Default}, Path=StretchMode}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
            </Grid.ColumnDefinitions>

            <!-- Inner grid with 4 listboxes layout -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="215"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="215"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- labels row -->
                    <RowDefinition Height="600"/>
                    <!-- big listboxes row -->
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <!-- page label -->
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <!-- page updown -->
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <!-- buttons -->
                </Grid.RowDefinitions>

                <!-- Column 0: Character List label -->
                <Label Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_rosterEditorSlotGame}"
                       Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                    <Label.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                    </Label.Effect>
                </Label>

                <!-- Column 2: Placeholder List label -->
                <Label Grid.Column="4" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_rosterEditorSlotPlaceHolder}"
                       Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                    <Label.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                    </Label.Effect>
                </Label>

                <!-- Column 4: Placeholder Costume List label -->
                <Label Grid.Column="6" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontFamily="{StaticResource NarutoFont}" Content="Placeholder Costumes"
                       Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                    <Label.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                    </Label.Effect>
                </Label>

                <!-- Column 6: Character Costume List label -->
                <Label Grid.Column="2" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_rosterEditorCostumePlaceHolder}"
                       Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                    <Label.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                    </Label.Effect>
                </Label>

                <!-- Column 0: Character List -->
                <ListBox Name="CharacterIconListPreview"
                         Grid.Column="0" Grid.Row="1"
                         ItemsSource="{Binding CharacterList}"
                         SelectedItem="{Binding SelectedCharacter}"
                         SelectedIndex="{Binding SelectedCharacterIndex}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseMove="LBoxSort_OnPreviewMouseMove"
                         Drop="LBoxSort_OnDrop"
                         DragOver="LBoxSort_OnDragOver"
                         DragEnter="LBoxSort_OnDragOver"
                         AllowDrop="True"
                         Background="{DynamicResource Toolbox_button_background_color_1}"
                         BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                         BorderThickness="1" >
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Width="64" Height="64" Source="{Binding CharacterIconPreview}" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill" />
                                <Label HorizontalAlignment="Left" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding CSP_code}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                                <Label HorizontalAlignment="Right" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding SlotIndex}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Column 2: Placeholder List -->
                <ListBox Name="CharacterPlaceHolderIconListPreview"
                         Grid.Column="4" Grid.Row="1"
                         ItemsSource="{Binding CharacterPlaceHolderList}"
                         SelectedItem="{Binding SelectedPlaceholderCharacter}"
                         SelectedIndex="{Binding SelectedPlaceholderCharacterIndex}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseMove="LBoxSort_OnPreviewMouseMove"
                         Drop="LBoxSort_OnDrop"
                         DragOver="LBoxSort_OnDragOver"
                         DragEnter="LBoxSort_OnDragOver"
                         AllowDrop="True"
                         Background="{DynamicResource Toolbox_button_background_color_1}"
                         BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                         BorderThickness="1" >
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Width="64" Height="64" Source="{Binding CharacterIconPreview}" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill" />
                                <Label HorizontalAlignment="Left" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding CSP_code}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                                <Label HorizontalAlignment="Right" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding SlotIndex}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Column 4: Placeholder Costume List (NEW) -->
                <ListBox Name="PlaceholderCostumeIconListPreview"
                         Grid.Column="6" Grid.Row="1"
                         ItemsSource="{Binding PlaceholderCostumePlaceHolderList}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseMove="LBoxSort_OnPreviewMouseMove"
                         Drop="LBoxSort_OnDrop"
                         DragOver="LBoxSort_OnDragOver"
                         DragEnter="LBoxSort_OnDragOver"
                         AllowDrop="True"
                         Background="{DynamicResource Toolbox_button_background_color_1}"
                         BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                         BorderThickness="1" >
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Width="64" Height="64" Source="{Binding CharacterIconPreview}" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill" />
                                <Label HorizontalAlignment="Left" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding CSP_code}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                                <Label HorizontalAlignment="Right" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding CostumeIndex}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Column 6: Character Costume List -->
                <ListBox Name="CharacterCostumeIconListPreview"
                         Grid.Column="2" Grid.Row="1"
                         ItemsSource="{Binding CostumePlaceHolderList}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseMove="LBoxSort_OnPreviewMouseMove"
                         Drop="LBoxSort_OnDrop"
                         DragOver="LBoxSort_OnDragOver"
                         DragEnter="LBoxSort_OnDragOver"
                         AllowDrop="True"
                         Background="{DynamicResource Toolbox_button_background_color_1}"
                         BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                         BorderThickness="1" >
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Width="64" Height="64" Source="{Binding CharacterIconPreview}" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Fill" />
                                <Label HorizontalAlignment="Left" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding CSP_code}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                                <Label HorizontalAlignment="Right" VerticalAlignment="Bottom" FontFamily="{StaticResource NarutoFont}" Content="{Binding CostumeIndex}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                                    <Label.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                                    </Label.Effect>
                                </Label>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Page label -->
                <Label Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="3" HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_rosterEditorPage}"
                       Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="10">
                    <Label.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="1" Color="Black"/>
                    </Label.Effect>
                </Label>

                <!-- Page updown -->
                <xctk:UShortUpDown Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="3" MinHeight="35"
                                   Minimum="1" Maximum="1000" Value="{Binding RosterPage_field}"
                                   Increment="1" VerticalContentAlignment="Center" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                   FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                   Background="{DynamicResource Toolbox_button_background_color_1}"
                                   BorderBrush="{DynamicResource Toolbox_button_border_color_1}" BorderThickness="1"/>

                <!-- Buttons -->
                <Button Command="{Binding SaveRosterCommand}" Content="{DynamicResource m_rosterEditorSave}"
                        Grid.Row="7" Grid.Column="4" Grid.ColumnSpan="3" MinHeight="35" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                        FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="12"/>

                <Button Command="{Binding RestoreRosterCommand}" Content="{DynamicResource m_rosterEditorRestore}"
                        Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" MinHeight="35" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                        FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="12"/>

            </Grid>
        </Grid>
    </Viewbox>
</Window>
